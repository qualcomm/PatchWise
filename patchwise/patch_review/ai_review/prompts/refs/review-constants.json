{
  "schema": "review-commits.constants.v1",
  "source_audit": {
    "pre_passed_context_files": 4,
    "on_demand_read_budget_per_patch": 6,
    "targeted_read_max_lines": 1500,
    "large_file_strategy": "read only the relevant function/section range"
  },
  "html_report": {
    "required_classes": [
      "review-header",
      "verdict-banner",
      "verdict-pill",
      "test-table"
    ],
    "required_cannot_apply_finding_class": "finding-card",
    "standard_verdicts": [
      "READY TO APPLY",
      "NEEDS FIXES",
      "NEEDS DISCUSSION",
      "CANNOT APPLY"
    ],
    "forbidden_labels": [
      "NEEDS CHANGES",
      "CHANGES REQUIRED",
      "CRITICAL \u2014",
      "CRITICAL --",
      "CRITICAL -"
    ],
    "forbidden_classes": [
      "page-header",
      "verdict-bar",
      "patch-section",
      "patch-verdict",
      "sev-tag"
    ],
    "standard_severities": [
      "[BUG]",
      "[CONCERN]",
      "[MINOR]",
      "[NIT]"
    ],
    "qgenie_footer_text": "Generated by AI agent (qgenie)"
  },
  "runtime_overrides": {
    "sparse_disabled_marker": "(sparse disabled by config)",
    "sparse_disabled_summary_note": "disabled by config"
  }
}
